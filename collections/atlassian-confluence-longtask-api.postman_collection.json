            "description": {
              "content": "Returns information about an active long-running task (e.g. space export),<br>such as how long it has been running and the percentage of the task that<br>has completed.<br><br>**[Permissions](https://confluence.atlassian.com/x/_AozKw) required**:<br>Permission to access the Confluence site ('Can use' global permission).",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "wiki",
                "rest",
                "api",
                "longtask",
                ":id"
              ],
              "host": [
                "{{baseUrl}}"
              ],
