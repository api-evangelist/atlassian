  "info": {
    "_postman_id": "1c8e6437-3844-45c1-b0ca-10f8ca7cd49c",
    "name": "Atlassian Confluence Content States API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Atlassian Confluence Content States API is a tool designed to help users manage and track changes to content within the Confluence platform. This API allows users to view the current state of content, such as whether it is in draft form, published, or archived, and make updates as needed. By using the Content States API, users can easily track the progress of their content, collaborate with team members, and ensure that all information is up to date and accurate.",
      "type": "text/plain"
    }
  }
