        {
          "id": "d963a0fe-0775-465a-90cd-eb10c352ccaf",
          "name": "Atlassian Remove Modules",
          "request": {
            "name": "Atlassian Remove Modules",
            "description": {
              "content": "This API operation allows developers to remove dynamically registered modules from an Atlassian Confluence Connect app. When called via DELETE request to the /atlassian-connect/1/app/module/dynamic endpoint, it removes previously added modules that were registered at runtime rather than being defined in the app descriptor. This is particularly useful for Connect apps that need to programmatically manage their module lifecycle, enabling them to clean up or deregister modules that are no longer needed without requiring a full app reinstallation or descriptor update. The operation requires proper authentication and authorization, and successfully removing a module will make it unavailable in the Confluence interface until it is registered again through the dynamic module registration API.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "atlassian-connect",
                "1",
                "app",
                "module",
                "dynamic"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "moduleKey",
                  "value": "<string>,<string>",
                  "description": "(Required) The key of the module to remove. To include multiple module keys, provide multiple copies of this parameter.\nFor example, `moduleKey=dynamic-attachment-entity-property&moduleKey=dynamic-select-field`.\nNonexistent keys are ignored."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Accept",
                "value": "*/*"
              }
            ],
            "method": "DELETE",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{bearerToken}}"
                }
              ]
            }
          },
          "response": [
            {
              "id": "4e131c71-0b7b-463f-902c-25d41b3f6065",
              "name": "Returned if the request is successful.",
              "originalRequest": {
                "url": {
                  "path": [
                    "atlassian-connect",
                    "1",
                    "app",
                    "module",
                    "dynamic"
                  ],
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "query": [
                    {
                      "key": "moduleKey",
                      "value": "<string>,<string>"
                    }
                  ],
                  "variable": []
                },
                "header": [
                  {
                    "description": {
                      "content": "Added as a part of security scheme: bearer",
                      "type": "text/plain"
                    },
                    "key": "Authorization",
                    "value": "Bearer <token>"
                  }
                ],
                "method": "DELETE",
                "body": {}
              },
