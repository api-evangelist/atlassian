        {
          "id": "733200ef-1045-4d3d-8765-6a1bf373892c",
          "name": "Atlassian Get Views",
          "request": {
            "name": "Atlassian Get Views",
            "description": {
              "content": "This API endpoint retrieves view analytics for a specific piece of Confluence content by its content ID. It returns data about how many times the content has been viewed, providing insights into content engagement and popularity. The endpoint uses a GET request to fetch view statistics for pages, blog posts, or other content types within a Confluence space, allowing administrators and content owners to track and analyze content consumption patterns.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "wiki",
                "rest",
                "api",
                "analytics",
                "content",
                ":contentId",
                "views"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "fromDate",
                  "value": "<string>",
                  "description": "The number of views for the content since the date."
                }
              ],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
