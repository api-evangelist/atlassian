  "info": {
    "_postman_id": "81e33266-7dfb-44a8-98b8-bfb675ad2b7c",
    "name": "Atlassian Confluence Search API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Atlassian Confluence Search API is a powerful tool that allows users to search for specific content within their Confluence site. With this API, users can quickly and easily find the information they need, whether it's a specific document, page, or even a comment. The search functionality is highly customizable, allowing users to filter results based on various criteria such as date, author, or content type. Additionally, the API provides advanced search options such as fuzzy search, phrase matching, and keyword highlighting, to help users pinpoint the exact information they are looking for.",
      "type": "text/plain"
    }
  }
