  "info": {
    "_postman_id": "1f06dbd8-eb30-415f-9932-b1d1f14aaa29",
    "name": "Atlassian Confluence Template API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Atlassian Confluence Template API is a tool that allows users to create and customize templates within the Confluence platform. This API enables users to design and save templates for various types of content, such as meeting notes, project plans, and documentation. With the Template API, users can streamline their workflow by quickly generating new pages with pre-defined layouts and formatting. This helps to maintain consistency across documents and ensures that important information is organized in a clear and structured manner. Additionally, the Template API allows users to easily collaborate with team members by sharing and reusing templates within the Confluence environment.",
      "type": "text/plain"
    }
  }
