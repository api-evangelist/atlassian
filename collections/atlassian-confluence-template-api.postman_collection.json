        {
          "id": "6898d9d6-2c80-48ab-8e95-4747e545c49a",
          "name": "Atlassian Get Blueprint Templates",
          "request": {
            "name": "Atlassian Get Blueprint Templates",
            "description": {
              "content": "Returns all templates provided by blueprints. Use this method to retrieve<br>all global blueprint templates or all blueprint templates in a space.<br><br>Note, all global blueprints are inherited by each space. Space blueprints<br>can be customised without affecting the global blueprints.<br><br>**[Permissions](https://confluence.atlassian.com/x/_AozKw) required**:<br>'View' permission for the space to view blueprints for the space and permission<br>to access the Confluence site ('Can use' global permission) to view global blueprints.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "wiki",
                "rest",
                "api",
                "template",
                "blueprint"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "spaceKey",
                  "value": "<string>",
                  "description": "The key of the space to be queried for templates. If the `spaceKey`\nis not specified, global blueprint templates will be returned."
                },
                {
                  "disabled": false,
                  "key": "start",
                  "value": "0",
                  "description": "The starting index of the returned templates."
                },
                {
                  "disabled": false,
                  "key": "limit",
                  "value": "25",
                  "description": "The maximum number of templates to return per page.\nNote, this may be restricted by fixed system limits."
                },
                {
                  "disabled": false,
                  "key": "expand",
                  "value": "<string>,<string>",
                  "description": "A multi-value parameter indicating which properties of the template\nto expand.\n\n- `body` returns the content of the template in storage format."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET"
