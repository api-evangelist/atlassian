{
  "opencollection": "1.0.0",
  "info": {
    "name": "Atlassian Confluence Longtask API",
    "version": "1.0.0"
  },
  "items": [
    {
      "info": {
        "name": "Long-Running Task",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Atlassian Get Long Running Task",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "//your-domain.atlassian.net/wiki/rest/api/longtask/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path",
                "description": "The ID of the task."
              }
            ]
          },
          "docs": "Returns information about an active long-running task (e.g. space export),<br>such as how long it has been running and the percentage of the task that<br>has completed.<br><br>**[Permissions](https://confluence.atlassian.com/x/_AozKw) required**:<br>Permission to access the Confluence site ('Can use' global permission)."
        }
      ]
    }
  ],
  "bundled": true
}