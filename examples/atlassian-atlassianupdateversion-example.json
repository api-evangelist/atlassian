{
  "operationId": "atlassianUpdateversion",
  "method": "PUT",
  "path": "/rest/api/3/version/{id}",
  "summary": "Atlassian Update Version",
  "requestExamples": [
    {
      "contentType": "application/json",
      "example": {
        "archived": false,
        "description": "An excellent version",
        "id": "10000",
        "name": "New Version 1",
