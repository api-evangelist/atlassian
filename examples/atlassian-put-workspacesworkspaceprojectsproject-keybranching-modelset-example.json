{
  "operationId": "put-workspacesworkspaceprojectsproject-keybranching-modelsetting",
  "method": "PUT",
  "path": "/workspaces/{workspace}/projects/{project_key}/branching-model/settings",
  "summary": "Atlassian Update the branching model config for a project",
  "requestExamples": [],
  "responseExamples": [
    {
      "status": "200",
      "contentType": "application/json",
      "name": "response",
      "example": {
        "development": {
          "use_mainbranch": true
        },
        "production": {
          "enabled": true,
          "use_mainbranch": false,
          "name": "production"
        },
        "branch_types": [
          {
            "kind": "bugfix",
            "enabled": true,
            "prefix": "bugfix/"
          },
          {
            "kind": "feature",
            "enabled": true,
            "prefix": "feature/"
          },
          {
            "kind": "hotfix",
            "prefix": "hotfix/"
          },
          {
            "kind": "release",
            "enabled": false
          }
        ]
      }
    }
  ]
}