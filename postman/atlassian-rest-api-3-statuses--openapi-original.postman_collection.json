                                  "key": "searchString",
                                  "value": "<string>"
                                },
                                {
                                  "description": "Category of the status to filter by. The supported values are: `TODO`, `IN_PROGRESS`, and `DONE`.",
                                  "key": "statusCategory",
                                  "value": "<string>"
                                }
                              ]
                            },
