                          "protocolProfileBehavior": {
                            "disableBodyPruning": true
                          },
                          "request": {
                            "method": "DELETE",
                            "header": [],
                            "url": {
                              "raw": "{{baseUrl}}/wiki/rest/api/template/:contentTemplateId",
                              "host": [
                                "{{baseUrl}}"
                              ],
