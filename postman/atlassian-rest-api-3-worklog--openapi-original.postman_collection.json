                                    "value": "application/json"
                                  }
                                ],
                                "url": {
                                  "raw": "{{baseUrl}}/rest/api/3/worklog/deleted?since=0",
                                  "host": [
                                    "{{baseUrl}}"
                                  ],
                                  "path": [
                                    "rest",
                                    "api",
                                    "3",
                                    "worklog",
                                    "deleted"
                                  ],
                                  "query": [
                                    {
                                      "description": "The date and time, as a UNIX timestamp in milliseconds, after which deleted worklogs are returned.",
                                      "key": "since",
                                      "value": "0"
                                    }
                                  ]
                                }
                              },
                              "status": "OK",
                              "code": 200,
                              "_postman_previewlanguage": "json",
                              "header": [
                                {
                                  "key": "Content-Type",
                                  "value": "application/json"
                                }
                              ],
                              "cookie": [],
                              "responseTime": null,
                              "body": "{\n  \"lastPage\": \"<boolean>\",\n  \"nextPage\": \"<uri>\",\n  \"self\": \"<uri>\",\n  \"since\": \"<long>\",\n  \"until\": \"<long>\",\n  \"values\": [\n    {\n      \"value\": \"reference #/components/schemas/ChangedWorklog not found in the OpenAPI spec\"\n    },\n    {\n      \"value\": \"reference #/components/schemas/ChangedWorklog not found in the OpenAPI spec\"\n    }\n  ]\n}",
