                        {
                          "name": "Atlassian Set Application Property",
                          "id": "d8d7be28-af7f-4d46-a708-5c8a0083063a",
                          "protocolProfileBehavior": {
                            "disableBodyPruning": true
                          },
                          "request": {
                            "method": "PUT",
                            "header": [
