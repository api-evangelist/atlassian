{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Label",
  "title": "Label",
  "required": [
    "id",
    "label",
    "name",
    "prefix"
  ],
  "type": "object",
  "properties": {
    "prefix": {
      "type": "string",
      "example": "example_value"
    },
    "name": {
      "type": "string",
      "example": "Example Title"
    },
    "id": {
      "type": "string",
      "example": "abc123"
    },
    "label": {
      "type": "string",
      "example": "Example Title"
    }
  }
}