{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Icon",
  "title": "Icon",
  "required": [
    "height",
    "isDefault",
    "path",
    "width"
  ],
  "type": "object",
  "nullable": true,
  "properties": {
    "path": {
      "type": "string",
      "example": "example_value"
    },
    "width": {
      "type": "integer",
      "format": "int32",
      "example": 10
    },
    "height": {
      "type": "integer",
      "format": "int32",
      "example": 10
    },
    "isDefault": {
      "type": "boolean",
      "example": true
    }
  },
  "description": "This object represents an icon. If used as a profilePicture, this may be returned as null, depending on the user's privacy setting."
}