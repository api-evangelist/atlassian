        "$ref": "#/components/schemas/AppWorkflowTransitionRule"
      },
      "type": "array"
    },
    "workflowId": {
      "$ref": "#/components/schemas/WorkflowId"
    }
  },
  "required": [
    "workflowId"
  ],
  "type": "object"
