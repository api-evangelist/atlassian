{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/BulkProjectPermissions",
  "title": "BulkProjectPermissions",
  "additionalProperties": false,
  "description": "Details of project permissions and associated issues and projects to look up.",
  "properties": {
    "issues": {
      "description": "List of issue IDs.",
      "items": {
        "format": "int64",
        "type": "integer"
      },
      "type": "array",
      "uniqueItems": true
    },
    "permissions": {
      "description": "List of project permissions.",
      "items": {
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "projects": {
      "description": "List of project IDs.",
      "items": {
        "format": "int64",
        "type": "integer"
      },
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "permissions"
  ],
  "type": "object"
}