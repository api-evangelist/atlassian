      "readOnly": true,
      "type": "integer"
    },
    "key": {
      "description": "The key of the created project.",
      "readOnly": true,
      "type": "string"
    },
    "self": {
      "description": "The URL of the created project.",
      "format": "uri",
      "readOnly": true,
      "type": "string"
    }
  },
  "required": [
    "id",
    "key",
    "self"
  ],
  "type": "object"
}