    "contentId",
    "contentType",
    "title"
  ],
  "type": "object",
  "properties": {
    "contentType": {
      "$ref": "#/components/schemas/LabeledContentType"
    },
    "contentId": {
      "type": "integer",
      "format": "int64"
    },
    "title": {
      "type": "string",
      "description": "Title of the content."
    }
  }
}