{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "task",
  "type": "object",
  "description": "A task object.",
  "properties": {
    "id": {
      "type": "integer"
    },
    "created_on": {
      "type": "string"
    },
    "updated_on": {
      "type": "string"
    },
    "state": {
      "type": "string"
    },
    "content": {
      "type": "object"
    },
    "pending": {
      "type": "boolean"
    },
    "resolved_on": {
      "type": "string",
      "description": "The ISO8601 timestamp for when the task was resolved."
    }
  }
}