{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ContentRestrictionArray",
  "title": "ContentRestrictionArray",
  "required": [
    "_links",
    "limit",
    "restrictionsHash",
    "results",
    "size",
    "start"
  ],
  "type": "object",
  "properties": {
    "results": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/ContentRestriction"
      },
      "example": []
    },
    "start": {
      "type": "integer",
      "format": "int32",
      "example": 10
    },
    "limit": {
      "type": "integer",
      "format": "int32",
      "example": 10
    },
    "size": {
      "type": "integer",
      "format": "int32",
      "example": 10
    },
    "restrictionsHash": {
      "type": "string",
      "description": "This property is used by the UI to figure out whether a set of restrictions\nhas changed.",
      "example": "example_value"
    },
    "_links": {
      "$ref": "#/components/schemas/GenericLinks"
    }
  }
}