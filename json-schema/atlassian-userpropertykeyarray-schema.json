    "limit": {
      "type": "integer",
      "format": "int32",
      "example": 10
    },
    "size": {
      "type": "integer",
      "format": "int32",
      "example": 10
    },
    "_links": {
      "$ref": "#/components/schemas/GenericLinks"
    }
  }
