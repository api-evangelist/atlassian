{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Watch",
  "title": "Watch",
  "required": [
    "contentId",
    "type",
    "watcher"
  ],
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "example": "example_value"
    },
    "watcher": {
      "$ref": "#/components/schemas/WatchUser"
    },
    "contentId": {
      "type": "integer",
      "format": "int64",
      "example": "500123"
    }
  }
}