{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/SearchPageResponseSearchResult",
  "title": "SearchPageResponseSearchResult",
  "required": [
    "_links",
    "cqlQuery",
    "limit",
    "results",
    "searchDuration",
    "size",
    "start",
    "totalSize"
  ],
  "type": "object",
  "properties": {
    "results": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/SearchResult"
      },
      "example": []
    },
    "start": {
      "type": "integer",
      "format": "int32",
      "example": 10
    },
    "limit": {
      "type": "integer",
      "format": "int32",
      "example": 10
    },
    "size": {
      "type": "integer",
      "format": "int32",
      "example": 10
    },
    "totalSize": {
      "type": "integer",
      "format": "int32",
      "example": 10
    },
    "cqlQuery": {
      "type": "string",
      "example": "example_value"
    },
    "searchDuration": {
      "type": "integer",
      "format": "int32",
      "example": 10
    },
    "archivedResultCount": {
      "type": "integer",
      "format": "int32",
      "example": 10
    },
    "_links": {
      "$ref": "#/components/schemas/GenericLinks"
    }
  }
}