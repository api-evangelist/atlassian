{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Content",
  "type": "object",
  "description": "Base object for all content types.",
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "description": "Can be \"page\", \"blogpost\", \"attachment\" or \"content\""
    },
    "status": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "ancestors": {
      "type": "array"
    },
    "operations": {
      "type": "array"
    },
    "body": {
      "type": "object"
    },
    "restrictions": {
      "type": "object"
    },
    "macroRenderedOutput": {
      "type": "object"
    },
    "extensions": {
      "type": "object"
    },
    "_expandable": {
      "type": "object"
    }
  }
}